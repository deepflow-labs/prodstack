{
  "mcpServers": {
    "shadcn": {
      "command": "npx",
      "args": ["shadcn@latest", "mcp"]
    },
    "convex": {
      "command": "npx",
      "args": ["convex@latest", "mcp"]
    },
    "figma": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://www.figma.com/mcp"],
      "env": {
        "FIGMA_API_TOKEN": "${FIGMA_API_TOKEN}"
      }
    },
    "linear": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.linear.app/mcp"]
    }
  }
}
