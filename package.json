{
  "name": "prodstack",
  "version": "1.0.0",
  "description": "Open-source SaaS starter kit — Convex, Next.js 15, shadcn/ui, AI-agent ready",
  "private": false,
  "scripts": {
    "dev": "next dev -p 3333",
    "dev:convex": "convex dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:convex": "vitest run --project convex",
    "test:ui": "vitest run --project frontend",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:report": "playwright show-report",
    "e2e:install": "playwright install --with-deps",
    "convex:codegen": "convex codegen",
    "convex:deploy": "convex deploy --yes",
    "storybook": "STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -p 6006",
    "build-storybook": "storybook build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "create-test-users": "npx tsx scripts/create-test-users.ts",
    "create-test-users:prod": "npx tsx scripts/create-test-users.ts --prod"
  },
