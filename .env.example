# Convex (from dashboard.convex.dev)
NEXT_PUBLIC_CONVEX_URL=https://<deployment>.convex.cloud

# Development only
NEXT_PUBLIC_API_URL=http://localhost:3333

# Optional: Figma MCP (from figma.com/developers > Personal access tokens)
FIGMA_API_TOKEN=

# Note: The following variables are set in the Convex dashboard, NOT here:
#   SITE_URL         — app origin (e.g. http://localhost:3333 for dev)
#   JWT_PRIVATE_KEY  — Ed25519 private key (auto-generated by @convex-dev/auth CLI)
#   JWKS             — corresponding public key set
#   RESEND_API_KEY   — from resend.com (for transactional email)
#
# Run: npx @convex-dev/auth --web-server-url http://localhost:3333
# See docs/setup-guide.md for full instructions.
